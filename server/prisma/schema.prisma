// EmpireIndia - Prisma Schema (Monopoly Edition)
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  username      String   @unique
  email         String   @unique
  passwordHash  String
  walletBalance Float    @default(5000000)
  dailyIncome   Float    @default(0)
  totalEarnings Float    @default(0)
  color         String   @default("#00ff88")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ownedCities    City[]          @relation("CityOwner")
  transactions   Transaction[]
  chests         DailyChest[]
  auctionBids    Auction[]       @relation("AuctionBidder")
  ownedAuctions  Auction[]       @relation("AuctionSeller")
  sentTrades     Trade[]         @relation("TradeSender")
  receivedTrades Trade[]         @relation("TradeReceiver")

  @@map("users")
}

model State {
  id               String  @id @default(uuid())
  name             String  @unique
  code             String  @unique
  totalGdp         Float
  population       Float   @default(0)
  capital          String  @default("")
  isUnionTerritory Boolean @default(false)
  totalCities      Int     @default(0)

  cities City[]

  @@map("states")
}

model City {
  id         String  @id @default(uuid())
  name       String
  code       String  @unique
  stateId    String
  gdp        Float
  population Float   @default(0)
  basePrice  Float
  ownerId    String?
  isForSale  Boolean @default(false)
  salePrice  Float?

  state State  @relation(fields: [stateId], references: [id])
  owner User?  @relation("CityOwner", fields: [ownerId], references: [id])

  transactions Transaction[]
  auctions     Auction[]
  chestSlot1   DailyChest[]  @relation("ChestCity1")
  chestSlot2   DailyChest[]  @relation("ChestCity2")
  chestSlot3   DailyChest[]  @relation("ChestCity3")
  chestBought  DailyChest[]  @relation("ChestPurchased")
  tradesFor    Trade[]       @relation("TradeCity")

  @@map("cities")
}

model Transaction {
  id         String   @id @default(uuid())
  type       String   // "purchase", "sale", "income", "auction_win", "trade"
  amount     Float
  cityId     String?
  userId     String
  sellerId   String?
  createdAt  DateTime @default(now())

  city City?  @relation(fields: [cityId], references: [id])
  user User   @relation(fields: [userId], references: [id])

  @@map("transactions")
}

model DailyChest {
  id          String   @id @default(uuid())
  userId      String
  date        String   // "2026-05-20" format, one chest per day
  city1Id     String
  city2Id     String
  city3Id     String
  purchasedId String?  // which one they bought (null = not yet bought)
  createdAt   DateTime @default(now())

  user      User   @relation(fields: [userId], references: [id])
  city1     City   @relation("ChestCity1", fields: [city1Id], references: [id])
  city2     City   @relation("ChestCity2", fields: [city2Id], references: [id])
  city3     City   @relation("ChestCity3", fields: [city3Id], references: [id])
  purchased City?  @relation("ChestPurchased", fields: [purchasedId], references: [id])

  @@unique([userId, date])
  @@map("daily_chests")
}

model Auction {
  id          String   @id @default(uuid())
  cityId      String
  sellerId    String
  startPrice  Float
  currentBid  Float?
  bidderId    String?
  endsAt      DateTime
  status      String   @default("active") // "active", "ended", "cancelled"
  createdAt   DateTime @default(now())

  city     City @relation(fields: [cityId], references: [id])
  seller   User @relation("AuctionSeller", fields: [sellerId], references: [id])
  bidder   User? @relation("AuctionBidder", fields: [bidderId], references: [id])

  @@map("auctions")
}

model Trade {
  id                String   @id @default(uuid())
  senderId          String
  receiverId        String
  offeredMoney      Float    @default(0)
  requestedCityId   String
  status            String   @default("pending") // "pending", "accepted", "declined", "countered"
  counterMoney      Float?   // if countered, the new price
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  sender   User  @relation("TradeSender", fields: [senderId], references: [id])
  receiver User  @relation("TradeReceiver", fields: [receiverId], references: [id])
  city     City  @relation("TradeCity", fields: [requestedCityId], references: [id])

  @@map("trades")
}
